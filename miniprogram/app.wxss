page {
  color: #111111;
  background:
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 5px),
    radial-gradient(circle, rgba(0, 0, 0, 0.035) 0, rgba(0, 0, 0, 0.035) 0.6px, transparent 1px),
    #eee9dd;
  background-size: 100% 5px, 13px 13px, 100% 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

text {
  letter-spacing: 0;
  text-shadow: 0.3px 0.3px 0.5px rgba(0, 0, 0, 0.12);
}

button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

input,
textarea {
  box-sizing: border-box;
}
