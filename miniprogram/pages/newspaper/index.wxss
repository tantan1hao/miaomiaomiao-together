page {
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #dfdfdf;
}

text,
view,
image,
input,
textarea,
button,
canvas {
  box-sizing: border-box;
}

.reader-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  padding-right: 7px;
  padding-bottom: 7px;
  padding-left: 7px;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.18) 0, transparent 18%, rgba(0, 0, 0, 0.035) 100%),
    repeating-linear-gradient(90deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 18px),
    #dfdfdf;
}

.edition-swiper {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  overflow: visible;
}

swiper-item {
  overflow: visible;
}

.paper-sheet {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  border: 1px solid rgba(0, 0, 0, 0.9);
  border-radius: 0;
  color: #0b0b0b;
  background:
    linear-gradient(90deg, rgba(0, 0, 0, 0.055) 0, rgba(255, 255, 255, 0.06) 4%, transparent 18%, transparent 84%, rgba(0, 0, 0, 0.048) 100%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.34) 0, transparent 9%, transparent 88%, rgba(0, 0, 0, 0.034) 100%),
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 4px),
    repeating-linear-gradient(90deg, rgba(0, 0, 0, 0.009) 0, rgba(0, 0, 0, 0.009) 1px, transparent 1px, transparent 7px),
    #f6f6f2;
  box-shadow:
    0 9px 20px rgba(0, 0, 0, 0.22),
    0 1px 0 rgba(255, 255, 255, 0.64),
    inset 6px 0 9px rgba(0, 0, 0, 0.028),
    inset -7px 0 11px rgba(0, 0, 0, 0.042);
  transform: rotate(-0.28deg);
  transform-origin: 52% 48%;
}

.front-edition {
  transform: rotate(-0.31deg) translateY(1px);
}

.ranking-edition {
  transform: rotate(0.24deg);
}

.submit-edition {
  transform: rotate(-0.2deg) translateX(1px);
}

.notice-edition {
  transform: rotate(0.18deg) translateY(1px);
}

.paper-inner text {
  text-shadow: 0.2px 0.2px 0.35px rgba(0, 0, 0, 0.1);
}

.paper-grain {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 0;
  opacity: 0.46;
  background:
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 3px),
    repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.36) 0, rgba(255, 255, 255, 0.36) 1px, transparent 1px, transparent 17px),
    linear-gradient(104deg, transparent 0, transparent 47%, rgba(0, 0, 0, 0.02) 48%, transparent 50%, transparent 100%),
    radial-gradient(circle, rgba(0, 0, 0, 0.052) 0, rgba(0, 0, 0, 0.052) 0.42px, transparent 0.88px),
    radial-gradient(circle, rgba(255, 255, 255, 0.68) 0, rgba(255, 255, 255, 0.68) 0.55px, transparent 1px);
  background-size: 100% 3px, 17px 100%, 100% 100%, 9px 9px, 14px 14px;
}

.paper-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 8px 8px 6px;
}

.masthead {
  flex: 0 0 auto;
}

.issue-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 18px;
  padding: 0 1px;
  border-top: 1px solid rgba(0, 0, 0, 0.82);
  border-bottom: 1px solid rgba(0, 0, 0, 0.72);
  color: #353535;
  font-size: 8px;
  font-weight: 800;
  line-height: 18px;
  white-space: nowrap;
}

.issue-strip text:first-child {
  color: #b31921;
}

.masthead-title {
  display: block;
  margin-top: 2px;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 34px;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1;
  text-align: center;
  text-shadow:
    0.35px 0.35px 0.5px rgba(0, 0, 0, 0.18),
    -0.2px 0 0.35px rgba(0, 0, 0, 0.08);
}

.masthead-subtitle {
  display: block;
  margin-top: 1px;
  color: #b31921;
  font-size: 9px;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 10px;
  text-align: center;
}

.section-title {
  display: block;
  padding: 5px 0 3px;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 26px;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1.1;
  text-align: center;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.16);
}

.double-rule {
  height: 6px;
  border-top: 2px solid rgba(0, 0, 0, 0.86);
  border-bottom: 1px solid rgba(0, 0, 0, 0.68);
}

.compact .double-rule {
  height: 6px;
}

.front-layout,
.submit-newspaper,
.notice-layout {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding-top: 5px;
}

.dense-front {
  gap: 4px;
}

.front-body {
  display: flex;
  flex: 1;
  min-height: 0;
  gap: 5px;
}

.front-main {
  display: flex;
  flex: 1 1 62%;
  min-width: 0;
  min-height: 0;
  flex-direction: column;
  padding-right: 5px;
  border-right: 1px solid rgba(0, 0, 0, 0.78);
}

.front-sidebar {
  display: flex;
  flex: 0 0 36%;
  min-width: 0;
  min-height: 0;
  flex-direction: column;
  gap: 5px;
}

.kicker,
.box-label,
.coupon-kicker {
  display: block;
  color: #b31921;
  font-size: 10px;
  font-weight: 900;
  line-height: 12px;
}

.lead-story {
  flex: 0 0 auto;
  padding-bottom: 4px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.44);
}

.newspaper-lead {
  flex: 1;
  min-height: 0;
  border-bottom: none;
}

.front-headline {
  display: -webkit-box;
  margin-top: 0;
  overflow: hidden;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 24px;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 0.98;
  text-shadow:
    0.3px 0.3px 0.5px rgba(0, 0, 0, 0.16),
    -0.15px 0 0.3px rgba(0, 0, 0, 0.07);
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.story-meta {
  display: flex;
  justify-content: space-between;
  gap: 4px;
  margin-top: 3px;
  padding: 2px 0;
  border-top: 1px solid rgba(0, 0, 0, 0.34);
  border-bottom: 1px solid rgba(0, 0, 0, 0.34);
  color: #444;
  font-size: 8px;
  font-weight: 800;
  line-height: 10px;
}

.story-meta text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lead-deck {
  display: -webkit-box;
  margin-top: 4px;
  overflow: hidden;
  color: #282828;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0;
  line-height: 1.24;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
}

.news-photo {
  position: relative;
  margin-top: 5px;
  overflow: hidden;
  border: 1px solid rgba(0, 0, 0, 0.9);
  background: #f2f2ee;
  box-shadow:
    inset 0 0 0 1px rgba(255, 255, 255, 0.26),
    0 2px 3px rgba(0, 0, 0, 0.08);
}

.news-photo::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  height: 82px;
  pointer-events: none;
  background:
    linear-gradient(150deg, rgba(255, 255, 255, 0.08) 0, rgba(255, 255, 255, 0) 42%, rgba(0, 0, 0, 0.07) 100%);
  box-shadow:
    inset 0 0 7px rgba(0, 0, 0, 0.14),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
}

.news-photo image {
  display: block;
}

.lead-photo {
  height: 102px;
}

.news-photo image,
.halftone-photo {
  width: 100%;
  height: 82px;
}

.halftone-photo {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 12px;
  background:
    radial-gradient(circle, rgba(0, 0, 0, 0.18) 0, rgba(0, 0, 0, 0.18) 1px, transparent 1.4px),
    linear-gradient(135deg, #eeeeea 0, #f8f8f4 50%, #deded9 100%);
  background-size: 8px 8px, 100% 100%;
}

.photo-score {
  display: block;
  color: #b31921;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 38px;
  font-weight: 900;
  line-height: 1;
}

.photo-name {
  display: block;
  margin-top: 4px;
  color: #050505;
  font-size: 16px;
  font-weight: 900;
  line-height: 1.1;
}

.photo-caption {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 20px;
  padding: 0 5px;
  border-top: 1px solid rgba(0, 0, 0, 0.82);
  color: #292929;
  font-size: 8px;
  font-weight: 800;
  line-height: 20px;
}

.brief-columns {
  display: flex;
  flex: 0 0 72px;
  gap: 5px;
  margin-top: 5px;
  padding-top: 5px;
  border-top: 2px solid rgba(0, 0, 0, 0.82);
}

.brief-item {
  flex: 1;
  min-width: 0;
  padding-right: 6px;
  border-right: 1px solid rgba(0, 0, 0, 0.48);
}

.brief-item:last-child {
  padding-right: 0;
  border-right: none;
}

.brief-title {
  display: -webkit-box;
  color: #050505;
  font-size: 12px;
  font-weight: 900;
  line-height: 1.15;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.brief-name {
  display: block;
  margin-top: 2px;
  overflow: hidden;
  color: #b31921;
  font-size: 9px;
  font-weight: 900;
  line-height: 1.1;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.brief-text {
  display: -webkit-box;
  margin-top: 3px;
  overflow: hidden;
  color: #303030;
  font-size: 10px;
  font-weight: 600;
  line-height: 1.22;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.side-module {
  padding: 5px 0;
  border-top: 2px solid rgba(0, 0, 0, 0.82);
}

.side-module:first-child {
  padding-top: 0;
  border-top: none;
}

.side-label {
  display: inline-block;
  padding-bottom: 1px;
  color: #b31921;
  font-size: 9px;
  font-weight: 900;
  line-height: 1;
}

.side-title {
  display: block;
  margin-top: 2px;
  color: #050505;
  font-size: 15px;
  font-weight: 900;
  line-height: 1.1;
  text-shadow: 0.25px 0.25px 0.45px rgba(0, 0, 0, 0.14);
}

.side-text {
  display: -webkit-box;
  margin-top: 3px;
  overflow: hidden;
  color: #303030;
  font-size: 10px;
  font-weight: 650;
  line-height: 1.22;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
}

.side-action {
  display: inline-block;
  margin-top: 4px;
  padding: 2px 4px;
  border: 1px solid #b31921;
  color: #b31921;
  font-size: 9px;
  font-weight: 900;
  line-height: 1.1;
  background: rgba(255, 255, 255, 0.42);
}

.mini-rank {
  display: flex;
  align-items: center;
  gap: 3px;
  min-height: 18px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.32);
  color: #050505;
  font-size: 9px;
  font-weight: 800;
  line-height: 1;
}

.mini-rank text:first-child {
  flex: 0 0 16px;
  color: #b31921;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 13px;
  font-weight: 900;
}

.mini-rank text:nth-child(2) {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-rank text:last-child {
  flex: 0 0 21px;
  text-align: right;
}

.front-wire {
  display: grid;
  flex: 0 0 50px;
  grid-template-columns: 1.24fr 1.24fr 0.86fr;
  gap: 4px;
  padding-top: 4px;
  border-top: 2px solid rgba(0, 0, 0, 0.82);
}

.wire-item {
  min-width: 0;
  padding: 4px 3px;
  border: 1px solid rgba(0, 0, 0, 0.82);
  color: #050505;
  text-align: center;
  background: rgba(246, 246, 242, 0.9);
}

.wire-vote {
  border-top: 3px solid #b31921;
}

.wire-side {
  display: grid;
  min-width: 0;
  gap: 3px;
}

.wire-small {
  padding: 2px 2px;
}

.wire-item text:first-child {
  display: block;
  font-size: 12px;
  font-weight: 900;
  line-height: 1.08;
}

.wire-small text:first-child {
  font-size: 10px;
}

.wire-item text:last-child {
  display: block;
  margin-top: 3px;
  color: #b31921;
  font-size: 8px;
  font-weight: 900;
  line-height: 1;
}

.wire-small text:last-child {
  margin-top: 1px;
  font-size: 7px;
}

.ranking-table {
  flex: 1;
  min-height: 0;
  padding-top: 4px;
  overflow: hidden;
}

.ranking-row {
  display: flex;
  min-height: 58px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.36);
}

.ranking-row.top-row {
  min-height: 22px;
  border-top: 1px solid rgba(0, 0, 0, 0.82);
  border-bottom: 2px solid rgba(0, 0, 0, 0.82);
  color: #b31921;
  font-size: 10px;
  font-weight: 900;
  line-height: 22px;
}

.rank-col {
  flex: 0 0 34px;
  padding-left: 2px;
}

.rank-number {
  color: #b31921;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 22px;
  font-weight: 900;
  line-height: 58px;
  text-shadow: 0.25px 0.25px 0.45px rgba(0, 0, 0, 0.13);
}

.dish-col {
  flex: 1;
  min-width: 0;
  padding-right: 6px;
}

.dish-info {
  padding: 4px 6px 3px 0;
}

.dish-name {
  display: block;
  overflow: hidden;
  color: #050505;
  font-size: 10px;
  font-weight: 800;
  line-height: 12px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-headline {
  display: -webkit-box;
  overflow: hidden;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 13px;
  font-weight: 900;
  line-height: 1.05;
  text-shadow: 0.25px 0.25px 0.45px rgba(0, 0, 0, 0.15);
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.dish-place {
  display: block;
  overflow: hidden;
  margin-top: 1px;
  color: #454545;
  font-size: 9px;
  font-weight: 600;
  line-height: 11px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score-col {
  flex: 0 0 52px;
  text-align: right;
}

.score-number {
  display: block;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 19px;
  font-weight: 900;
  line-height: 25px;
}

.score-meta {
  display: block;
  color: #606060;
  font-size: 8px;
  font-weight: 700;
  line-height: 11px;
}

.score-info {
  padding-top: 4px;
}

.rating-strip {
  display: flex;
  gap: 3px;
}

.vote-strip {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 3px;
}

.vote-label {
  flex: 0 0 auto;
  height: 16px;
  padding: 0 4px;
  border: 1px solid #b31921;
  color: #b31921;
  font-size: 9px;
  font-weight: 900;
  line-height: 14px;
  background: #fff;
}

.rating-button {
  width: 18px;
  height: 16px;
  border: 1px solid #b31921;
  color: #b31921;
  font-size: 10px;
  font-weight: 900;
  line-height: 14px;
  text-align: center;
  background: #fff;
}

.submit-lead {
  flex: 0 0 auto;
  padding-bottom: 5px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.44);
}

.submit-headline {
  display: block;
  margin-top: 2px;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 23px;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.16);
}

.coupon {
  flex: 0 0 144px;
  margin-top: 7px;
  padding: 5px;
  border: 1px dashed rgba(0, 0, 0, 0.76);
  background:
    repeating-linear-gradient(90deg, rgba(179, 25, 33, 0.08) 0, rgba(179, 25, 33, 0.08) 1px, transparent 1px, transparent 9px),
    #f7f7f3;
}

.coupon-border {
  height: 100%;
  padding: 10px 11px;
  border: 2px solid rgba(0, 0, 0, 0.82);
}

.coupon-title {
  display: block;
  margin-top: 8px;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 24px;
  font-weight: 900;
  line-height: 1.1;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.16);
}

.coupon-text {
  display: block;
  margin-top: 8px;
  color: #333;
  font-size: 12px;
  font-weight: 800;
  line-height: 1.32;
}

.editor-note {
  margin-top: 7px;
  padding-top: 6px;
  border-top: 2px solid rgba(0, 0, 0, 0.82);
}

.editor-note text:first-child {
  display: block;
  color: #050505;
  font-size: 16px;
  font-weight: 900;
  line-height: 1.2;
}

.editor-note text:last-child {
  display: block;
  margin-top: 5px;
  color: #333;
  font-size: 12px;
  font-weight: 600;
  line-height: 1.34;
}

.announcement-box,
.category-box {
  flex: 0 0 auto;
  padding: 8px;
  border: 2px solid rgba(0, 0, 0, 0.82);
  background:
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.014) 0, rgba(0, 0, 0, 0.014) 1px, transparent 1px, transparent 5px),
    #f7f7f3;
}

.announcement-box {
  min-height: 112px;
}

.announcement-text {
  display: -webkit-box;
  margin-top: 6px;
  overflow: hidden;
  color: #111;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 18px;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1.16;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.16);
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
}

.category-box {
  min-height: 108px;
  margin-top: 7px;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-top: 7px;
}

.category-chip {
  min-width: 55px;
  height: 23px;
  padding: 0 8px;
  border: 1px solid rgba(0, 0, 0, 0.78);
  color: #050505;
  font-size: 12px;
  font-weight: 900;
  line-height: 21px;
  text-align: center;
  background: #f7f7f3;
}

.category-chip:nth-child(3n + 1) {
  border-color: #b31921;
  color: #b31921;
}

.notice-actions {
  display: flex;
  gap: 6px;
  margin-top: 7px;
}

.notice-actions view {
  flex: 1;
  min-width: 0;
  padding: 8px 6px;
  border-top: 4px solid #b31921;
  border-right: 1px solid rgba(0, 0, 0, 0.78);
  border-bottom: 1px solid rgba(0, 0, 0, 0.78);
  border-left: 1px solid rgba(0, 0, 0, 0.78);
  background: #f7f7f3;
}

.notice-actions text:first-child {
  display: block;
  color: #050505;
  font-size: 13px;
  font-weight: 900;
  line-height: 1.25;
}

.notice-actions text:last-child {
  display: block;
  margin-top: 5px;
  color: #b31921;
  font-size: 9px;
  font-weight: 900;
}

.paper-footer {
  display: flex;
  flex: 0 0 19px;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 3px;
  border-top: 1px solid rgba(0, 0, 0, 0.72);
  color: #4b4b4b;
  font-size: 9px;
  font-weight: 800;
  line-height: 11px;
}

.submit-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  background: rgba(0, 0, 0, 0.54);
}

.submit-sheet {
  position: fixed;
  right: 24rpx;
  bottom: 28rpx;
  left: 24rpx;
  z-index: 11;
  max-height: 86vh;
  padding: 24rpx;
  overflow-y: auto;
  border: 2rpx solid rgba(0, 0, 0, 0.84);
  border-radius: 0;
  background:
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.014) 0, rgba(0, 0, 0, 0.014) 1rpx, transparent 1rpx, transparent 5rpx),
    #f7f7f3;
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.3);
}

.sheet-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-bottom: 18rpx;
  margin-bottom: 18rpx;
  border-bottom: 4rpx double rgba(0, 0, 0, 0.82);
}

.sheet-kicker,
.sheet-title {
  display: block;
}

.sheet-kicker {
  color: #b31921;
  font-size: 20rpx;
  font-weight: 900;
}

.sheet-title {
  margin-top: 6rpx;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
}

.sheet-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  color: #050505;
  font-size: 46rpx;
  line-height: 1;
}

.field,
.field-grid {
  margin-bottom: 18rpx;
}

.field-grid {
  display: flex;
  gap: 14rpx;
}

.field-grid .field {
  flex: 1;
  min-width: 0;
}

.field-label {
  display: block;
  margin-bottom: 8rpx;
  color: #050505;
  font-size: 25rpx;
  font-weight: 800;
}

input,
textarea {
  width: 100%;
  border: 2rpx solid rgba(0, 0, 0, 0.78);
  border-radius: 0;
  color: #050505;
  background: #fbfbf7;
  font-size: 28rpx;
}

input {
  height: 72rpx;
  padding: 0 20rpx;
}

textarea {
  min-height: 136rpx;
  padding: 16rpx 20rpx;
  line-height: 1.38;
}

.image-picker {
  min-height: 188rpx;
  overflow: hidden;
  border: 2rpx dashed #b31921;
  border-radius: 0;
  background: #fbfbf7;
}

.image-preview {
  width: 100%;
  height: 240rpx;
}

.image-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 188rpx;
  color: #b31921;
  font-weight: 900;
  gap: 10rpx;
}

.image-empty text:last-child {
  color: #555;
  font-size: 24rpx;
  font-weight: 700;
}

.image-meta {
  display: flex;
  justify-content: space-between;
  margin: 12rpx 0 22rpx;
  color: #555;
  font-size: 24rpx;
}

.image-meta text:last-child {
  color: #b31921;
  font-weight: 900;
}

.submit-button {
  width: 100%;
  height: 80rpx;
  border-radius: 0;
  color: #fff;
  background: #b31921;
  font-size: 30rpx;
  font-weight: 900;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.18);
}

.submit-button::after {
  border: none;
}

/* Poster newspaper pass: denser blocks, harder ink, red print marks. */
.reader-page {
  padding-right: 10px;
  padding-bottom: 10px;
  padding-left: 10px;
  background:
    radial-gradient(circle, rgba(0, 0, 0, 0.04) 0, rgba(0, 0, 0, 0.04) 0.7px, transparent 1.1px),
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 6px),
    #d9d7d1;
  background-size: 11px 11px, 100% 6px, 100% 100%;
}

.paper-sheet {
  border: none;
  background:
    linear-gradient(96deg, rgba(0, 0, 0, 0.055) 0, transparent 7%, transparent 86%, rgba(0, 0, 0, 0.05) 100%),
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 4px),
    radial-gradient(circle, rgba(0, 0, 0, 0.04) 0, rgba(0, 0, 0, 0.04) 0.55px, transparent 0.95px),
    #f7f5ee;
  background-size: 100% 100%, 100% 4px, 12px 12px, 100% 100%;
  box-shadow:
    0 12px 26px rgba(0, 0, 0, 0.26),
    0 0 0 1px rgba(0, 0, 0, 0.24),
    inset 0 0 0 1px rgba(255, 255, 255, 0.4);
}

.paper-inner {
  padding: 7px 7px 6px;
}

.issue-strip {
  height: 17px;
  border-top: 2px solid rgba(0, 0, 0, 0.9);
  border-bottom: 1px solid rgba(0, 0, 0, 0.8);
  color: #121212;
  font-size: 8px;
}

.issue-strip text:first-child,
.masthead-subtitle,
.kicker,
.side-label,
.box-label,
.coupon-kicker {
  color: #b31921;
}

.issue-strip text:last-child {
  color: #6b6b6b;
  font-size: 7.5px;
  font-weight: 600;
  letter-spacing: 0.5px;
}

.poster-masthead {
  position: relative;
  min-height: 62px;
  overflow: hidden;
  border-bottom: 1px solid rgba(0, 0, 0, 0.82);
}

.poster-masthead::before {
  content: '';
  position: absolute;
  left: -8px;
  right: 36%;
  bottom: 0;
  height: 11px;
  background:
    repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.34) 0, rgba(255, 255, 255, 0.34) 2px, transparent 2px, transparent 7px),
    #b31921;
}

.masthead-title {
  position: relative;
  z-index: 2;
  margin-top: 4px;
  padding-right: 100rpx;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 36px;
  font-weight: 900;
  line-height: 0.94;
  text-align: left;
  text-shadow:
    0.45px 0.45px 0.65px rgba(0, 0, 0, 0.22),
    -0.2px 0 0.35px rgba(0, 0, 0, 0.12);
}

.masthead-sketch {
  position: absolute;
  right: 4px;
  top: 10px;
  width: 76px;
  height: 50px;
  transform: rotate(-7deg);
}

.sketch-head,
.sketch-body,
.sketch-pan,
.sketch-steam {
  position: absolute;
  border: 2px solid #111;
}

.sketch-head {
  left: 22px;
  top: 0;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: #f7f5ee;
}

.sketch-body {
  left: 16px;
  top: 17px;
  width: 26px;
  height: 24px;
  border-top: none;
  transform: skewX(-14deg);
}

.sketch-pan {
  right: 0;
  top: 24px;
  width: 34px;
  height: 13px;
  border-radius: 50%;
  background:
    radial-gradient(circle, rgba(179, 25, 33, 0.28) 0, rgba(179, 25, 33, 0.28) 2px, transparent 3px),
    #f7f5ee;
}

.sketch-steam {
  right: 14px;
  top: 4px;
  width: 24px;
  height: 28px;
  border-width: 0 0 0 2px;
  border-radius: 50%;
  transform: rotate(28deg);
}

.double-rule {
  height: 5px;
  border-top: 3px solid #111;
  border-bottom: 1px solid rgba(0, 0, 0, 0.62);
}

.front-layout {
  padding-top: 4px;
}

.front-body {
  gap: 4px;
}

.front-main {
  flex-basis: 62%;
  padding-right: 4px;
  border-right: 2px solid #111;
}

.front-sidebar {
  flex-basis: 37%;
  gap: 4px;
}

.front-headline {
  font-size: 25px;
  line-height: 0.92;
  -webkit-line-clamp: 3;
}

.story-meta {
  border-top: 2px solid #111;
  border-bottom: 1px solid rgba(0, 0, 0, 0.72);
  color: #111;
}

.lead-photo {
  height: 116px;
  border-width: 2px;
}

.news-photo image,
.halftone-photo {
  height: 92px;
}

.halftone-photo {
  position: relative;
  padding: 8px 9px 8px 104px;
  background:
    radial-gradient(circle, rgba(0, 0, 0, 0.22) 0, rgba(0, 0, 0, 0.22) 1px, transparent 1.6px),
    linear-gradient(135deg, #efeee8 0, #fbfaf4 54%, #dedbd2 100%);
  background-size: 7px 7px, 100% 100%;
}

.plate-sketch {
  position: absolute;
  left: 10px;
  top: 8px;
  width: 82px;
  height: 68px;
  transform: rotate(-9deg);
}

.plate-ring {
  position: absolute;
  left: 7px;
  top: 7px;
  width: 54px;
  height: 54px;
  border: 4px solid #111;
  border-radius: 50%;
  background:
    radial-gradient(circle, rgba(179, 25, 33, 0.4) 0, rgba(179, 25, 33, 0.4) 9px, transparent 10px),
    repeating-linear-gradient(45deg, transparent 0, transparent 5px, rgba(0, 0, 0, 0.18) 5px, rgba(0, 0, 0, 0.18) 6px),
    #f7f5ee;
}

.plate-line {
  position: absolute;
  height: 2px;
  background: #111;
  transform-origin: left center;
}

.line-a {
  left: 48px;
  top: 22px;
  width: 34px;
  transform: rotate(-20deg);
}

.line-b {
  left: 50px;
  top: 34px;
  width: 28px;
  transform: rotate(17deg);
}

.photo-score {
  color: #b31921;
  font-size: 34px;
}

.photo-name {
  font-size: 14px;
}

.lead-deck,
.brief-text,
.side-text {
  color: #222;
  font-size: 10px;
  line-height: 1.18;
}

.brief-columns {
  flex-basis: 62px;
  margin-top: 4px;
  padding-top: 4px;
  border-top: 3px solid #111;
}

.brief-title {
  font-size: 12px;
  line-height: 1.05;
}

.side-module {
  padding: 5px 4px;
  border: 2px solid #111;
  background: rgba(247, 245, 238, 0.72);
}

.side-module:first-child {
  border-top: 2px solid #111;
}

.ranking-teaser {
  color: #fff;
  background:
    repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.12) 0, rgba(255, 255, 255, 0.12) 1px, transparent 1px, transparent 7px),
    #b31921;
}

.ranking-teaser .side-label,
.ranking-teaser .side-title,
.ranking-teaser .mini-rank,
.ranking-teaser .mini-rank text:first-child {
  color: #fff;
}

.ranking-teaser .mini-rank {
  border-bottom-color: rgba(255, 255, 255, 0.42);
}

.side-title {
  font-size: 14px;
  line-height: 1;
}

.front-wire {
  flex-basis: 35px;
  padding-top: 4px;
  border-top: 3px solid #111;
}

.wire-item {
  padding: 3px 2px;
  border: 2px solid #111;
  background: #f7f5ee;
  box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.18);
}

.wire-item text:first-child {
  font-size: 11px;
}

.front-sponsor {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 19px;
  margin-top: 3px;
  padding: 0 5px;
  color: #111;
  border-top: 2px solid #111;
  border-bottom: 3px solid #b31921;
  background:
    linear-gradient(90deg, rgba(179, 25, 33, 0.18), transparent 34%),
    #f7f5ee;
  font-size: 8px;
  font-weight: 900;
}

.front-sponsor text:first-child {
  color: #b31921;
  font-size: 10px;
}

.section-title,
.submit-headline,
.announcement-text,
.coupon-title {
  font-family: Georgia, 'Times New Roman', serif;
  text-shadow:
    0.45px 0.45px 0.65px rgba(0, 0, 0, 0.22),
    -0.2px 0 0.35px rgba(0, 0, 0, 0.1);
}

/* ===== 首页 v2：参考海报版式 ===== */

.issue-banner {
  display: flex;
  align-items: center;
  gap: 4px;
  height: 22px;
  padding: 0 3px;
