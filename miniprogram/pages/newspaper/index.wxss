page {
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #dfdfdf;
}

text,
view,
image,
input,
textarea,
button,
canvas {
  box-sizing: border-box;
}

.reader-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  padding-right: 7px;
  padding-bottom: 7px;
  padding-left: 7px;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.18) 0, transparent 18%, rgba(0, 0, 0, 0.035) 100%),
    repeating-linear-gradient(90deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 18px),
    #dfdfdf;
}

.edition-swiper {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  overflow: visible;
}

swiper-item {
  overflow: visible;
}

.paper-sheet {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  border: 1px solid rgba(0, 0, 0, 0.9);
  border-radius: 0;
  color: #0b0b0b;
  background:
    linear-gradient(90deg, rgba(0, 0, 0, 0.055) 0, rgba(255, 255, 255, 0.06) 4%, transparent 18%, transparent 84%, rgba(0, 0, 0, 0.048) 100%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.34) 0, transparent 9%, transparent 88%, rgba(0, 0, 0, 0.034) 100%),
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 4px),
    repeating-linear-gradient(90deg, rgba(0, 0, 0, 0.009) 0, rgba(0, 0, 0, 0.009) 1px, transparent 1px, transparent 7px),
    #f6f6f2;
  box-shadow:
    0 9px 20px rgba(0, 0, 0, 0.22),
    0 1px 0 rgba(255, 255, 255, 0.64),
    inset 6px 0 9px rgba(0, 0, 0, 0.028),
    inset -7px 0 11px rgba(0, 0, 0, 0.042);
  transform: rotate(-0.28deg);
  transform-origin: 52% 48%;
}

.front-edition {
  transform: rotate(-0.31deg) translateY(1px);
}

.ranking-edition {
  transform: rotate(0.24deg);
}

.submit-edition {
  transform: rotate(-0.2deg) translateX(1px);
}

.notice-edition {
  transform: rotate(0.18deg) translateY(1px);
}

.paper-inner text {
  text-shadow: 0.2px 0.2px 0.35px rgba(0, 0, 0, 0.1);
}

.paper-grain {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 0;
  opacity: 0.46;
  background:
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 3px),
    repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.36) 0, rgba(255, 255, 255, 0.36) 1px, transparent 1px, transparent 17px),
    linear-gradient(104deg, transparent 0, transparent 47%, rgba(0, 0, 0, 0.02) 48%, transparent 50%, transparent 100%),
    radial-gradient(circle, rgba(0, 0, 0, 0.052) 0, rgba(0, 0, 0, 0.052) 0.42px, transparent 0.88px),
    radial-gradient(circle, rgba(255, 255, 255, 0.68) 0, rgba(255, 255, 255, 0.68) 0.55px, transparent 1px);
  background-size: 100% 3px, 17px 100%, 100% 100%, 9px 9px, 14px 14px;
}

.paper-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 8px 8px 6px;
}

.masthead {
  flex: 0 0 auto;
}

.issue-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 18px;
  padding: 0 1px;
  border-top: 1px solid rgba(0, 0, 0, 0.82);
  border-bottom: 1px solid rgba(0, 0, 0, 0.72);
  color: #353535;
  font-size: 8px;
  font-weight: 800;
  line-height: 18px;
  white-space: nowrap;
}

.issue-strip text:first-child {
  color: #b31921;
}

.masthead-title {
  display: block;
  margin-top: 2px;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 34px;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1;
  text-align: center;
  text-shadow:
    0.35px 0.35px 0.5px rgba(0, 0, 0, 0.18),
    -0.2px 0 0.35px rgba(0, 0, 0, 0.08);
}

.masthead-subtitle {
  display: block;
  margin-top: 1px;
  color: #b31921;
  font-size: 9px;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 10px;
  text-align: center;
}

.section-title {
  display: block;
  padding: 5px 0 3px;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 26px;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1.1;
  text-align: center;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.16);
}

.double-rule {
  height: 6px;
  border-top: 2px solid rgba(0, 0, 0, 0.86);
  border-bottom: 1px solid rgba(0, 0, 0, 0.68);
}

.compact .double-rule {
  height: 6px;
}

.front-layout,
.submit-newspaper,
.notice-layout {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding-top: 5px;
}

.dense-front {
  gap: 4px;
}

.front-body {
  display: flex;
  flex: 1;
  min-height: 0;
  gap: 5px;
}

.front-main {
  display: flex;
  flex: 1 1 62%;
  min-width: 0;
  min-height: 0;
  flex-direction: column;
  padding-right: 5px;
  border-right: 1px solid rgba(0, 0, 0, 0.78);
}

.front-sidebar {
  display: flex;
  flex: 0 0 36%;
  min-width: 0;
  min-height: 0;
  flex-direction: column;
  gap: 5px;
}

.kicker,
.box-label,
.coupon-kicker {
  display: block;
  color: #b31921;
  font-size: 10px;
  font-weight: 900;
  line-height: 12px;
}

.lead-story {
  flex: 0 0 auto;
  padding-bottom: 4px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.44);
}

.newspaper-lead {
  flex: 1;
  min-height: 0;
  border-bottom: none;
}

.front-headline {
  display: -webkit-box;
  margin-top: 0;
  overflow: hidden;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 24px;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 0.98;
  text-shadow:
    0.3px 0.3px 0.5px rgba(0, 0, 0, 0.16),
    -0.15px 0 0.3px rgba(0, 0, 0, 0.07);
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.story-meta {
  display: flex;
  justify-content: space-between;
  gap: 4px;
  margin-top: 3px;
  padding: 2px 0;
  border-top: 1px solid rgba(0, 0, 0, 0.34);
  border-bottom: 1px solid rgba(0, 0, 0, 0.34);
  color: #444;
  font-size: 8px;
  font-weight: 800;
  line-height: 10px;
}

.story-meta text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lead-deck {
  display: -webkit-box;
  margin-top: 4px;
  overflow: hidden;
  color: #282828;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0;
  line-height: 1.24;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
}

.news-photo {
  position: relative;
  margin-top: 5px;
  overflow: hidden;
  border: 1px solid rgba(0, 0, 0, 0.9);
  background: #f2f2ee;
  box-shadow:
    inset 0 0 0 1px rgba(255, 255, 255, 0.26),
    0 2px 3px rgba(0, 0, 0, 0.08);
}

.news-photo::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  height: 82px;
  pointer-events: none;
  background:
    linear-gradient(150deg, rgba(255, 255, 255, 0.08) 0, rgba(255, 255, 255, 0) 42%, rgba(0, 0, 0, 0.07) 100%);
  box-shadow:
    inset 0 0 7px rgba(0, 0, 0, 0.14),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
}

.news-photo image {
  display: block;
}

.lead-photo {
  height: 102px;
}

.news-photo image,
.halftone-photo {
  width: 100%;
  height: 82px;
}

.halftone-photo {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 12px;
  background:
    radial-gradient(circle, rgba(0, 0, 0, 0.18) 0, rgba(0, 0, 0, 0.18) 1px, transparent 1.4px),
    linear-gradient(135deg, #eeeeea 0, #f8f8f4 50%, #deded9 100%);
  background-size: 8px 8px, 100% 100%;
}

.photo-score {
  display: block;
  color: #b31921;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 38px;
  font-weight: 900;
  line-height: 1;
}

.photo-name {
  display: block;
  margin-top: 4px;
  color: #050505;
  font-size: 16px;
  font-weight: 900;
  line-height: 1.1;
}

.photo-caption {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 20px;
  padding: 0 5px;
  border-top: 1px solid rgba(0, 0, 0, 0.82);
  color: #292929;
  font-size: 8px;
  font-weight: 800;
  line-height: 20px;
}

.brief-columns {
  display: flex;
  flex: 0 0 72px;
  gap: 5px;
  margin-top: 5px;
  padding-top: 5px;
  border-top: 2px solid rgba(0, 0, 0, 0.82);
}

.brief-item {
  flex: 1;
  min-width: 0;
  padding-right: 6px;
  border-right: 1px solid rgba(0, 0, 0, 0.48);
}

.brief-item:last-child {
  padding-right: 0;
  border-right: none;
}

.brief-title {
  display: block;
  color: #050505;
  font-size: 12px;
  font-weight: 900;
  line-height: 1.15;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.brief-text {
  display: -webkit-box;
  margin-top: 3px;
  overflow: hidden;
  color: #303030;
  font-size: 10px;
  font-weight: 600;
  line-height: 1.22;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.side-module {
  padding: 5px 0;
  border-top: 2px solid rgba(0, 0, 0, 0.82);
}

.side-module:first-child {
  padding-top: 0;
  border-top: none;
}

.side-label {
  display: inline-block;
  padding-bottom: 1px;
  color: #b31921;
  font-size: 9px;
  font-weight: 900;
  line-height: 1;
}

.side-title {
  display: block;
  margin-top: 2px;
  color: #050505;
  font-size: 15px;
  font-weight: 900;
  line-height: 1.1;
  text-shadow: 0.25px 0.25px 0.45px rgba(0, 0, 0, 0.14);
}

.side-text {
  display: -webkit-box;
  margin-top: 3px;
  overflow: hidden;
  color: #303030;
  font-size: 10px;
  font-weight: 650;
  line-height: 1.22;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
}

.mini-rank {
  display: flex;
  align-items: center;
  gap: 3px;
  min-height: 18px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.32);
  color: #050505;
  font-size: 9px;
  font-weight: 800;
  line-height: 1;
}

.mini-rank text:first-child {
  flex: 0 0 16px;
  color: #b31921;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 13px;
  font-weight: 900;
}

.mini-rank text:nth-child(2) {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-rank text:last-child {
  flex: 0 0 21px;
  text-align: right;
}

.front-wire {
  display: flex;
  flex: 0 0 40px;
  gap: 4px;
  padding-top: 4px;
  border-top: 2px solid rgba(0, 0, 0, 0.82);
}

.wire-item {
  flex: 1;
  min-width: 0;
  padding: 4px 3px;
  border: 1px solid rgba(0, 0, 0, 0.82);
  color: #050505;
  text-align: center;
  background: rgba(246, 246, 242, 0.9);
}

.wire-item text:first-child {
  display: block;
  font-size: 12px;
  font-weight: 900;
  line-height: 1.08;
}

.wire-item text:last-child {
  display: block;
  margin-top: 3px;
  color: #b31921;
  font-size: 8px;
  font-weight: 900;
  line-height: 1;
}

.ranking-table {
  flex: 1;
  min-height: 0;
  padding-top: 4px;
  overflow: hidden;
}

.ranking-row {
  display: flex;
  min-height: 43px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.36);
}

.ranking-row.top-row {
  min-height: 22px;
  border-top: 1px solid rgba(0, 0, 0, 0.82);
  border-bottom: 2px solid rgba(0, 0, 0, 0.82);
  color: #b31921;
  font-size: 10px;
  font-weight: 900;
  line-height: 22px;
}

.rank-col {
  flex: 0 0 34px;
  padding-left: 2px;
}

.rank-number {
  color: #b31921;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 22px;
  font-weight: 900;
  line-height: 43px;
  text-shadow: 0.25px 0.25px 0.45px rgba(0, 0, 0, 0.13);
}

.dish-col {
  flex: 1;
  min-width: 0;
  padding-right: 6px;
}

.dish-info {
  padding: 4px 6px 3px 0;
}

.dish-name {
  display: block;
  overflow: hidden;
  color: #050505;
  font-size: 13px;
  font-weight: 900;
  line-height: 16px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-place {
  display: block;
  overflow: hidden;
  margin-top: 2px;
  color: #454545;
  font-size: 10px;
  font-weight: 600;
  line-height: 12px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score-col {
  flex: 0 0 52px;
  text-align: right;
}

.score-number {
  display: block;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 19px;
  font-weight: 900;
  line-height: 25px;
}

.score-meta {
  display: block;
  color: #606060;
  font-size: 8px;
  font-weight: 700;
  line-height: 11px;
}

.score-info {
  padding-top: 4px;
}

.rating-strip {
  display: flex;
  gap: 3px;
  margin-top: 2px;
}

.rating-button {
  width: 18px;
  height: 16px;
  border: 1px solid #b31921;
  color: #b31921;
  font-size: 10px;
  font-weight: 900;
  line-height: 14px;
  text-align: center;
  background: #fff;
}

.submit-lead {
  flex: 0 0 auto;
  padding-bottom: 5px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.44);
}

.submit-headline {
  display: block;
  margin-top: 2px;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 23px;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.16);
}

.coupon {
  flex: 0 0 144px;
  margin-top: 7px;
  padding: 5px;
  border: 1px dashed rgba(0, 0, 0, 0.76);
  background:
    repeating-linear-gradient(90deg, rgba(179, 25, 33, 0.08) 0, rgba(179, 25, 33, 0.08) 1px, transparent 1px, transparent 9px),
    #f7f7f3;
}

.coupon-border {
  height: 100%;
  padding: 10px 11px;
  border: 2px solid rgba(0, 0, 0, 0.82);
}

.coupon-title {
  display: block;
  margin-top: 8px;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 24px;
  font-weight: 900;
  line-height: 1.1;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.16);
}

.coupon-text {
  display: block;
  margin-top: 8px;
  color: #333;
  font-size: 12px;
  font-weight: 800;
  line-height: 1.32;
}

.editor-note {
  margin-top: 7px;
  padding-top: 6px;
  border-top: 2px solid rgba(0, 0, 0, 0.82);
}

.editor-note text:first-child {
  display: block;
  color: #050505;
  font-size: 16px;
  font-weight: 900;
  line-height: 1.2;
}

.editor-note text:last-child {
  display: block;
  margin-top: 5px;
  color: #333;
  font-size: 12px;
  font-weight: 600;
  line-height: 1.34;
}

.announcement-box,
.category-box {
  flex: 0 0 auto;
  padding: 8px;
  border: 2px solid rgba(0, 0, 0, 0.82);
  background:
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.014) 0, rgba(0, 0, 0, 0.014) 1px, transparent 1px, transparent 5px),
    #f7f7f3;
}

.announcement-box {
  min-height: 112px;
}

.announcement-text {
  display: -webkit-box;
  margin-top: 6px;
  overflow: hidden;
  color: #111;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 18px;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1.16;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.16);
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
}

.category-box {
  min-height: 108px;
  margin-top: 7px;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-top: 7px;
}

.category-chip {
  min-width: 55px;
  height: 23px;
  padding: 0 8px;
  border: 1px solid rgba(0, 0, 0, 0.78);
  color: #050505;
  font-size: 12px;
  font-weight: 900;
  line-height: 21px;
  text-align: center;
  background: #f7f7f3;
}

.category-chip:nth-child(3n + 1) {
  border-color: #b31921;
  color: #b31921;
}

.notice-actions {
  display: flex;
  gap: 6px;
  margin-top: 7px;
}

.notice-actions view {
  flex: 1;
  min-width: 0;
  padding: 8px 6px;
  border-top: 4px solid #b31921;
  border-right: 1px solid rgba(0, 0, 0, 0.78);
  border-bottom: 1px solid rgba(0, 0, 0, 0.78);
  border-left: 1px solid rgba(0, 0, 0, 0.78);
  background: #f7f7f3;
}

.notice-actions text:first-child {
  display: block;
  color: #050505;
  font-size: 13px;
  font-weight: 900;
  line-height: 1.25;
}

.notice-actions text:last-child {
  display: block;
  margin-top: 5px;
  color: #b31921;
  font-size: 9px;
  font-weight: 900;
}

.paper-footer {
  display: flex;
  flex: 0 0 19px;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 3px;
  border-top: 1px solid rgba(0, 0, 0, 0.72);
  color: #4b4b4b;
  font-size: 9px;
  font-weight: 800;
  line-height: 11px;
}

.page-turn-canvas {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 8;
  pointer-events: none;
}

.page-fold {
  position: fixed;
  z-index: 7;
  border: 1px solid rgba(0, 0, 0, 0.34);
  background:
    linear-gradient(90deg, rgba(0, 0, 0, 0.18) 0, rgba(248, 248, 244, 0.98) 18%, rgba(244, 244, 240, 0.98) 48%, rgba(0, 0, 0, 0.16) 100%),
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.022) 0, rgba(0, 0, 0, 0.022) 1px, transparent 1px, transparent 4px);
  box-shadow:
    -10px 0 18px rgba(0, 0, 0, 0.2),
    inset 6px 0 9px rgba(255, 255, 255, 0.42),
    inset -5px 0 8px rgba(0, 0, 0, 0.24);
  pointer-events: none;
  transition: width 150ms ease-out, opacity 150ms ease-out, transform 150ms ease-out;
}

.page-fold-next {
  right: 7px;
  border-radius: 1px;
  clip-path: polygon(0 0, 100% 1%, 94% 50%, 100% 99%, 0 100%);
  transform: perspective(480px) rotateY(-36deg) skewY(-1.2deg);
  transform-origin: right center;
}

.page-fold-prev {
  left: 7px;
  border-radius: 1px;
  clip-path: polygon(100% 0, 0 1%, 6% 50%, 0 99%, 100% 100%);
  transform: perspective(480px) rotateY(36deg) skewY(1.2deg);
  transform-origin: left center;
}

.submit-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  background: rgba(0, 0, 0, 0.54);
}

.submit-sheet {
  position: fixed;
  right: 24rpx;
  bottom: 28rpx;
  left: 24rpx;
  z-index: 11;
  max-height: 86vh;
  padding: 24rpx;
  overflow-y: auto;
  border: 2rpx solid rgba(0, 0, 0, 0.84);
  border-radius: 0;
  background:
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.014) 0, rgba(0, 0, 0, 0.014) 1rpx, transparent 1rpx, transparent 5rpx),
    #f7f7f3;
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.3);
}

.sheet-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-bottom: 18rpx;
  margin-bottom: 18rpx;
  border-bottom: 4rpx double rgba(0, 0, 0, 0.82);
}

.sheet-kicker,
.sheet-title {
  display: block;
}

.sheet-kicker {
  color: #b31921;
  font-size: 20rpx;
  font-weight: 900;
}

.sheet-title {
  margin-top: 6rpx;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
}

.sheet-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  color: #050505;
  font-size: 46rpx;
  line-height: 1;
}

.field,
.field-grid {
  margin-bottom: 18rpx;
}

.field-grid {
  display: flex;
  gap: 14rpx;
}

.field-grid .field {
  flex: 1;
  min-width: 0;
}

.field-label {
  display: block;
  margin-bottom: 8rpx;
  color: #050505;
  font-size: 25rpx;
  font-weight: 800;
}

input,
textarea {
  width: 100%;
  border: 2rpx solid rgba(0, 0, 0, 0.78);
  border-radius: 0;
  color: #050505;
  background: #fbfbf7;
  font-size: 28rpx;
}

input {
  height: 72rpx;
  padding: 0 20rpx;
}

textarea {
  min-height: 136rpx;
  padding: 16rpx 20rpx;
  line-height: 1.38;
}

.image-picker {
  min-height: 188rpx;
  overflow: hidden;
  border: 2rpx dashed #b31921;
  border-radius: 0;
  background: #fbfbf7;
}

.image-preview {
  width: 100%;
  height: 240rpx;
}

.image-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 188rpx;
  color: #b31921;
  font-weight: 900;
  gap: 10rpx;
}

.image-empty text:last-child {
  color: #555;
  font-size: 24rpx;
  font-weight: 700;
}

.image-meta {
  display: flex;
  justify-content: space-between;
  margin: 12rpx 0 22rpx;
  color: #555;
  font-size: 24rpx;
}

.image-meta text:last-child {
  color: #b31921;
  font-weight: 900;
}

.submit-button {
  width: 100%;
  height: 80rpx;
  border-radius: 0;
  color: #fff;
  background: #b31921;
  font-size: 30rpx;
  font-weight: 900;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.18);
}

.submit-button::after {
  border: none;
}
