/* Functional fill pass: use the lead-card blank area without changing the page grid. */
.random-panel {
  flex: 0 0 auto;
  margin-top: 6px;
  padding: 5px 7px 6px;
  border-top: 1px dotted rgba(0, 0, 0, 0.36);
  border-bottom: 1px dotted rgba(0, 0, 0, 0.22);
  background:
    repeating-linear-gradient(90deg, rgba(179, 25, 33, 0.04) 0, rgba(179, 25, 33, 0.04) 1px, transparent 1px, transparent 12px),
    rgba(179, 25, 33, 0.045);
}

.random-card {
  position: relative;
  flex: 1;
  min-height: 0;
  justify-content: flex-start;
  border-style: double;
  overflow: hidden;
  transform-origin: 50% 55%;
  transition: transform 120ms ease-out;
}

.random-card::after {
  content: '';
  position: absolute;
  top: -16%;
  bottom: -16%;
  left: -36%;
  width: 34%;
  opacity: 0;
  background:
    repeating-linear-gradient(0deg, rgba(179, 25, 33, 0.22) 0, rgba(179, 25, 33, 0.22) 1px, transparent 1px, transparent 6px),
    linear-gradient(90deg, transparent, rgba(179, 25, 33, 0.16), transparent);
  transform: skewX(-12deg);
  pointer-events: none;
}

.random-card-rolling {
  animation: random-card-press 520ms cubic-bezier(0.18, 0.72, 0.18, 1);
}

.random-card-rolling::after {
  animation: random-red-swipe 520ms ease-out;
}

.random-card-rolling .random-label::before {
  animation: random-dot-stamp 520ms ease-out;
}

.random-card-rolling .random-refresh {
  animation: random-refresh-tick 520ms steps(2, end);
}

.random-card-rolling .random-body {
  animation: random-type-slide 520ms cubic-bezier(0.18, 0.72, 0.18, 1);
}

.random-card-rolling .random-shop {
  animation: random-ink-pulse 520ms ease-out;
}

.random-card-rolling .random-place {
  animation: random-place-fade 520ms ease-out;
}

.random-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 7px;
}

.random-label,
.random-refresh {
  color: #b31921;
  font-size: 10px;
  font-weight: 900;
  line-height: 1.1;
}

.random-card .random-head {
  padding-bottom: 5px;
  border-bottom: 1px dotted rgba(0, 0, 0, 0.34);
}

.random-label::before {
  content: '荐';
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 14px;
  height: 14px;
  margin-right: 4px;
  color: #fff;
  background: #b31921;
  font-size: 9px;
  line-height: 14px;
}

.random-card .random-label::before {
  content: '';
  width: 7px;
  height: 7px;
  margin-right: 5px;
  border-radius: 50%;
  line-height: 7px;
}

.random-refresh {
  flex: 0 0 auto;
}

.random-card .random-refresh {
  font-size: 9px;
}

.random-body {
  margin-top: 4px;
}

.random-card .random-body {
  margin-top: 8px;
}

.random-shop {
  display: block;
  overflow: hidden;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 16px;
  font-weight: 900;
  line-height: 1.12;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.random-card .random-shop {
  display: -webkit-box;
  white-space: normal;
  word-break: break-all;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.random-place {
  display: block;
  margin-top: 2px;
  overflow: hidden;
  color: #333;
  font-size: 10px;
  font-weight: 800;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

@keyframes random-card-press {
  0% {
    transform: rotate(0deg) translateY(0);
  }
  22% {
    transform: rotate(-0.35deg) translateY(1px);
  }
  56% {
    transform: rotate(0.28deg) translateY(-1px);
  }
  100% {
    transform: rotate(0deg) translateY(0);
  }
}

@keyframes random-red-swipe {
  0% {
    opacity: 0;
    transform: translateX(0) skewX(-12deg);
  }
  26% {
    opacity: 0.72;
  }
  72% {
    opacity: 0.28;
  }
  100% {
    opacity: 0;
    transform: translateX(430%) skewX(-12deg);
  }
}

@keyframes random-dot-stamp {
  0%,
  100% {
    transform: scale(1);
  }
  28% {
    transform: scale(0.72);
  }
  54% {
    transform: scale(1.28);
  }
}

@keyframes random-refresh-tick {
  0%,
  100% {
    transform: translateX(0);
  }
  50% {
    transform: translateX(2px);
  }
}

@keyframes random-type-slide {
  0% {
    opacity: 1;
    transform: translateY(0);
  }
  28% {
    opacity: 0;
    transform: translateY(-8px);
  }
  44% {
    opacity: 0;
    transform: translateY(8px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes random-ink-pulse {
  0%,
  100% {
    text-shadow: 0.25px 0.25px 0.45px rgba(0, 0, 0, 0.12);
  }
  54% {
    text-shadow:
      0.4px 0.4px 0.7px rgba(0, 0, 0, 0.28),
      -0.3px 0 0 rgba(179, 25, 33, 0.18);
  }
}

@keyframes random-place-fade {
  0%,
  100% {
    opacity: 1;
  }
  34% {
    opacity: 0;
  }
}

/* 风味榜窗口宽度不变，菜名允许两行完整露出。 */
.rank-card .mini-rank {
  align-items: flex-start;
  gap: 4px;
}

.mini-rank-num {
  flex: 0 0 6px;
  width: 6px;
  height: 6px;
  margin-top: 5px;
  border-radius: 50%;
  color: transparent;
  background: #b31921;
  font-size: 0;
  line-height: 6px;
}

.mini-rank-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 1px;
}

.mini-rank-name {
  display: -webkit-box;
  overflow: hidden;
  white-space: normal;
  text-overflow: clip;
  word-break: break-all;
  line-height: 1.16;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.mini-rank-shop {
  display: block;
  overflow: hidden;
  color: #555;
  font-size: 8.5px;
  font-weight: 700;
  line-height: 1.14;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-rank-score {
  padding-top: 2px;
}

.mini-rank-arrow {
  display: none;
}

.front-edition .paper-footer text:nth-child(3) {
  color: #101010;
  font-weight: 900;
  text-align: right;
}

/* Compress lead story and fill the lower blank area with two secondary dishes. */
.lead-card .front-headline {
  font-size: 21px;
  line-height: 1.05;
  -webkit-line-clamp: 2;
}

.lead-card .lead-photo,
.lead-card .lead-photo image {
  height: 104px;
}

.lead-card .lead-photo image {
  transform: scaleX(1.04) scaleY(0.86);
  transform-origin: center;
}

.lead-meta-row {
  margin-top: 6px;
}

.lead-name {
  font-size: 16px;
  line-height: 1.08;
}

.lead-stat-row {
  gap: 8px;
  margin-top: 3px;
  padding-bottom: 4px;
}

.info-row {
  gap: 6px;
  padding: 3px 0;
}

.info-label {
  font-size: 9px;
  line-height: 12px;
}

.info-text {
  font-size: 9px;
  line-height: 1.25;
}

.lead-briefs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-auto-rows: minmax(0, 1fr);
  gap: 5px;
  flex: 1 1 auto;
  min-height: 0;
  align-content: stretch;
  align-items: stretch;
  margin-top: 4px;
  padding-top: 4px;
  border-top: 2px solid #101010;
}

.lead-brief {
  display: flex;
  flex-direction: column;
  min-width: 0;
  min-height: 0;
  padding-left: 5px;
  border-left: 1px dotted rgba(0, 0, 0, 0.36);
}

.lead-brief:first-child {
  padding-left: 0;
  border-left: none;
}

.lead-brief-label {
  position: absolute;
  left: 3px;
  top: 3px;
  display: inline-block;
  padding: 1px 4px;
  color: #fff;
  background: #b31921;
  font-size: 8px;
  font-weight: 900;
  line-height: 1.15;
}

.lead-brief-media {
  position: relative;
  flex: 1 1 auto;
  min-height: 68px;
  height: auto;
  margin-bottom: 3px;
  overflow: hidden;
  border: 1px solid rgba(0, 0, 0, 0.72);
  background: #f1efe8;
}

.lead-brief-media image {
  display: block;
  width: 100%;
  height: 100%;
  filter: grayscale(1) contrast(1.18);
}

.lead-brief-title {
  display: -webkit-box;
  overflow: hidden;
  color: #101010;
  font-family: 'Songti SC', STSong, SimSun, Georgia, serif;
  font-size: 11px;
  font-weight: 900;
  line-height: 1.05;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}

.lead-brief-meta {
  display: flex;
  justify-content: space-between;
  gap: 4px;
  margin-top: 2px;
  color: #b31921;
  font-size: 9px;
  font-weight: 900;
  line-height: 1.1;
}

.lead-brief-meta text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lead-brief-meta text:first-child {
  flex: 1;
  min-width: 0;
  color: #101010;
}

.lead-brief-text {
  display: -webkit-box;
  margin-top: 2px;
  overflow: hidden;
  color: #333;
  font-size: 9px;
  font-weight: 700;
  line-height: 1.15;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}
