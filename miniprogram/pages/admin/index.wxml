<wxs src="../../utils/format.wxs" module="fmt" />
<view class="container">
  <view class="header">
    <text class="title">{{schoolName}} - 管理后台</text>
    <text class="subtitle">管理食堂店铺信息</text>
  </view>

  <view class="stats-section">
    <view class="section-title">数据统计</view>
    <view class="stats-card">
      <view class="stats-item">
        <text class="stats-value">{{fmt.formatNumber(schoolStats.today)}}</text>
        <text class="stats-label">今日抽奖</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-value">{{fmt.formatNumber(schoolStats.total)}}</text>
        <text class="stats-label">累计抽奖</text>
      </view>
    </view>
  </view>

  <view class="announcement-section">
    <view class="section-title">公告管理</view>
    <view class="announcement-input-wrap">
      <input class="announcement-input" placeholder="请输入公告内容" value="{{announcement}}" bindinput="onAnnouncementInput" />
      <view class="announcement-btn" bindtap="saveAnnouncement">保存</view>
    </view>
  </view>

  <view class="canteen-section">
    <view class="section-header">
      <text class="section-title">食堂管理</text>
      <view class="add-btn" bindtap="showAddCanteenModal">+ 添加食堂</view>
    </view>

    <view class="canteen-list">
      <view class="canteen-item" wx:for="{{canteenList}}" wx:key="_id" wx:for-item="canteen">
        <view class="canteen-header" bindtap="toggleCanteen" data-canteen="{{canteen._id}}">
          <view class="canteen-info">
            <text class="canteen-name">{{canteen.name}}</text>
            <text class="canteen-count">{{canteen.totalShops}}家店铺</text>
          </view>
          <view class="canteen-actions">
            <text class="canteen-arrow {{canteen.expanded ? 'expanded' : ''}}">▼</text>
            <view class="action-btn delete" catchtap="deleteCanteen" data-canteen="{{canteen}}">删除</view>
          </view>
        </view>
        
        <view class="floor-list" wx:if="{{canteen.expanded}}">
          <view class="floor-header">
            <text class="floor-label">楼层列表</text>
            <view class="add-floor-btn" catchtap="showAddFloorModal" data-canteen="{{canteen}}">+ 添加楼层</view>
          </view>
          
          <view class="floor-item" wx:for="{{canteen.floors}}" wx:key="name" wx:for-item="floor">
            <view class="floor-info" bindtap="toggleFloor" data-canteen="{{canteen._id}}" data-floor="{{floor.name}}">
              <view class="floor-info-left">
                <text class="floor-name">{{floor.name}}</text>
                <text class="floor-count">{{floor.shops.length}}家</text>
              </view>
              <view class="floor-actions">
                <text class="floor-arrow {{floor.expanded ? 'expanded' : ''}}">▼</text>
                <view class="action-btn delete" catchtap="deleteFloor" data-canteen="{{canteen}}" data-floor="{{floor}}">删除</view>
              </view>
            </view>
            
            <view class="shop-list" wx:if="{{floor.expanded}}">
              <view class="shop-item" wx:for="{{floor.shops}}" wx:key="*this" wx:for-item="shop">
                <text class="shop-name">{{shop}}</text>
                <view class="shop-actions">
                  <view class="shop-edit" catchtap="showShopEditModal" data-canteen="{{canteen}}" data-floor="{{floor.name}}" data-shop="{{shop}}">编辑</view>
                  <view class="shop-delete" catchtap="deleteShop" data-canteen="{{canteen}}" data-floor="{{floor.name}}" data-shop="{{shop}}">删除</view>
                </view>
              </view>
              
              <view class="add-shop-row">
                <input class="add-shop-input" placeholder="输入店铺名称" value="{{floor.newShopName}}" data-canteen="{{canteen._id}}" data-floor="{{floor.name}}" bindinput="onShopInput" />
                <view class="add-shop-btn" catchtap="addShop" data-canteen="{{canteen}}" data-floor="{{floor.name}}">添加</view>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:if="{{canteenList.length === 0}}">
        暂无食堂数据，请添加食堂
      </view>
    </view>
  </view>

  <view class="bottom-actions">
    <text class="admin-info" wx:if="{{schoolAdmin}}">管理员：{{schoolAdmin}}</text>
    <view class="back-btn" bindtap="goBack">返回首页</view>
  </view>

  <view class="modal" wx:if="{{showCanteenModal}}">
    <view class="modal-mask" bindtap="closeCanteenModal"></view>
    <view class="modal-content">
      <text class="modal-title">添加食堂</text>
      <view class="form-item">
        <text class="form-label">食堂名称</text>
        <input class="form-input" placeholder="请输入食堂名称" value="{{newCanteenName}}" bindinput="onCanteenNameInput" />
      </view>
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="closeCanteenModal">取消</view>
        <view class="modal-btn confirm" bindtap="addCanteen">添加</view>
      </view>
    </view>
  </view>

  <view class="modal" wx:if="{{showFloorModal}}">
    <view class="modal-mask" bindtap="closeFloorModal"></view>
    <view class="modal-content">
      <text class="modal-title">添加楼层</text>
      <view class="form-item">
        <text class="form-label">楼层名称</text>
        <input class="form-input" placeholder="请输入楼层名称，如：一楼" value="{{newFloorName}}" bindinput="onFloorNameInput" />
      </view>
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="closeFloorModal">取消</view>
        <view class="modal-btn confirm" bindtap="addFloor">添加</view>
      </view>
    </view>
  </view>

  <view class="modal" wx:if="{{showShopEditModal}}">
    <view class="modal-mask" bindtap="closeShopEditModal"></view>
    <view class="modal-content shop-edit-modal">
      <text class="modal-title">编辑店铺信息</text>
      <text class="modal-subtitle">{{currentEditShop}}</text>
      
      <view class="form-item">
        <text class="form-label">招牌菜品</text>
        <input class="form-input" placeholder="如：黄焖鸡米饭、黄焖排骨" value="{{shopEditData.signature}}" bindinput="onShopEditInput" data-field="signature" />
      </view>
      
      <view class="form-item">
        <text class="form-label">营业时间</text>
        <view class="time-inputs">
          <input class="form-input time-input" placeholder="开始时间" value="{{shopEditData.openTime}}" bindinput="onShopEditInput" data-field="openTime" />
          <text class="time-separator">-</text>
          <input class="form-input time-input" placeholder="结束时间" value="{{shopEditData.closeTime}}" bindinput="onShopEditInput" data-field="closeTime" />
        </view>
      </view>
      
      <view class="form-item">
        <text class="form-label">人均消费（元）</text>
        <view class="price-inputs">
          <input class="form-input price-input" type="number" placeholder="最低" value="{{shopEditData.minPrice}}" bindinput="onShopEditInput" data-field="minPrice" />
          <text class="price-separator">-</text>
          <input class="form-input price-input" type="number" placeholder="最高" value="{{shopEditData.maxPrice}}" bindinput="onShopEditInput" data-field="maxPrice" />
        </view>
      </view>
      
      <view class="form-item">
        <text class="form-label">特色标签（用逗号分隔）</text>
        <input class="form-input" placeholder="如：分量足,味道好,上菜快" value="{{shopEditData.tagsStr}}" bindinput="onShopEditInput" data-field="tagsStr" />
      </view>
      
      <view class="form-item">
        <text class="form-label">店铺简介</text>
        <textarea class="form-textarea" placeholder="请输入店铺简介..." value="{{shopEditData.description}}" bindinput="onShopEditInput" data-field="description" />
      </view>
      
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="closeShopEditModal">取消</view>
        <view class="modal-btn confirm" bindtap="saveShopEdit">保存</view>
      </view>
    </view>
  </view>
</view>
