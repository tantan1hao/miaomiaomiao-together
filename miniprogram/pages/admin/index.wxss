page {
  background-color: #1a1a2e;
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  padding-bottom: 150rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #eaeaea;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #888888;
}

.stats-section {
  background-color: #16213e;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: #1a1a2e;
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4fc3f7;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #888888;
}

.stats-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #2d3a5a;
}

.announcement-section {
  background-color: #16213e;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #eaeaea;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.announcement-input-wrap {
  display: flex;
  gap: 16rpx;
}

.announcement-input {
  flex: 1;
  height: 72rpx;
  background-color: #1a1a2e;
  border: 2rpx solid #2d3a5a;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #eaeaea;
  box-sizing: border-box;
}

.announcement-btn {
  width: 120rpx;
  height: 72rpx;
  background-color: #4fc3f7;
  color: #1a1a2e;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.canteen-section {
  background-color: #16213e;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.add-btn {
  font-size: 26rpx;
  color: #4fc3f7;
  padding: 8rpx 20rpx;
  background-color: rgba(79, 195, 247, 0.1);
  border-radius: 8rpx;
}

.canteen-list {

}

.canteen-item {
  background-color: #1a1a2e;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.canteen-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
}

.canteen-info {
  display: flex;
  flex-direction: column;
}

.canteen-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #eaeaea;
  margin-bottom: 6rpx;
}

.canteen-count {
  font-size: 24rpx;
  color: #4fc3f7;
}

.canteen-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.canteen-arrow {
  font-size: 24rpx;
  color: #888888;
  transition: transform 0.3s;
}

.canteen-arrow.expanded {
  transform: rotate(180deg);
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.action-btn.delete {
  background-color: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
}

.floor-list {
  border-top: 2rpx solid #2d3a5a;
  padding: 20rpx;
}

.floor-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.floor-label {
  font-size: 24rpx;
  color: #888888;
}

.add-floor-btn {
  font-size: 24rpx;
  color: #4fc3f7;
  padding: 6rpx 16rpx;
  background-color: rgba(79, 195, 247, 0.1);
  border-radius: 6rpx;
}

.floor-item {
  margin-bottom: 16rpx;
}

.floor-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 16rpx;
  background-color: #16213e;
  border-radius: 12rpx;
}

.floor-info-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.floor-name {
  font-size: 28rpx;
  color: #b0b0b0;
}

.floor-count {
  font-size: 22rpx;
  color: #4fc3f7;
  background-color: #1a1a2e;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.floor-arrow {
  font-size: 20rpx;
  color: #888888;
  transition: transform 0.3s;
}

.floor-arrow.expanded {
  transform: rotate(180deg);
}

.floor-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.shop-list {
  padding: 16rpx;
  background-color: #0f0f1a;
  border-radius: 12rpx;
  margin-top: 12rpx;
}

.shop-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 16rpx;
  background-color: #16213e;
  border-radius: 10rpx;
  margin-bottom: 12rpx;
}

.shop-name {
  font-size: 28rpx;
  color: #eaeaea;
}

.shop-actions {
  display: flex;
  gap: 12rpx;
}

.shop-edit {
  font-size: 24rpx;
  color: #4fc3f7;
  padding: 8rpx 20rpx;
  background-color: rgba(79, 195, 247, 0.1);
  border-radius: 8rpx;
}

.shop-delete {
  font-size: 24rpx;
  color: #ff6b6b;
  padding: 8rpx 20rpx;
  background-color: rgba(255, 107, 107, 0.1);
  border-radius: 8rpx;
}

.add-shop-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.add-shop-input {
  flex: 1;
  height: 72rpx;
  background-color: #16213e;
  border: 2rpx solid #2d3a5a;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #eaeaea;
  box-sizing: border-box;
}

.add-shop-btn {
  width: 120rpx;
  height: 72rpx;
  background-color: #4fc3f7;
  color: #1a1a2e;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: #888888;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background-color: #1a1a2e;
  border-top: 2rpx solid #2d3a5a;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.admin-info {
  font-size: 24rpx;
  color: #888888;
}

.back-btn {
  height: 88rpx;
  background-color: #4fc3f7;
  color: #1a1a2e;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background-color: #16213e;
  border-radius: 24rpx;
  padding: 40rpx;
  border: 2rpx solid #2d3a5a;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #eaeaea;
  margin-bottom: 32rpx;
  text-align: center;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #1a1a2e;
  border: 2rpx solid #2d3a5a;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #eaeaea;
  box-sizing: border-box;
}

.modal-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background-color: #2d3a5a;
  color: #888888;
}

.modal-btn.confirm {
  background-color: #4fc3f7;
  color: #1a1a2e;
}

.shop-edit-modal {
  max-height: 80vh;
  overflow-y: auto;
}

.modal-subtitle {
  font-size: 26rpx;
  color: #4fc3f7;
  text-align: center;
  margin-bottom: 24rpx;
}

.time-inputs,
.price-inputs {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.time-input,
.price-input {
  flex: 1;
}

.time-separator,
.price-separator {
  color: #888888;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background-color: #1a1a2e;
  border: 2rpx solid #2d3a5a;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #eaeaea;
  box-sizing: border-box;
}
