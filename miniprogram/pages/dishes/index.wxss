page {
  background: #fff7e8;
  color: #111116;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 64rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff7e8 0%, #fffdf8 52%, #edf8f5 100%);
}

.cover {
  min-height: 360rpx;
  border-radius: 16rpx;
  padding: 34rpx;
  box-sizing: border-box;
  background:
    linear-gradient(135deg, rgba(17, 17, 22, 0.86), rgba(17, 17, 22, 0.52)),
    linear-gradient(135deg, #f2543d 0%, #f7ca45 44%, #1b8f8f 100%);
  color: #ffffff;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.cover-copy {
  display: flex;
  flex-direction: column;
}

.kicker {
  font-size: 22rpx;
  color: #e8ff55;
  font-weight: 900;
  margin-bottom: 18rpx;
}

.title {
  font-size: 78rpx;
  line-height: 0.95;
  font-weight: 900;
}

.school {
  margin-top: 18rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.82);
  max-width: 560rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cover-score {
  align-self: flex-end;
  display: flex;
  align-items: flex-end;
  gap: 18rpx;
}

.cover-score .score {
  font-size: 72rpx;
  line-height: 1;
  color: #e8ff55;
  font-weight: 900;
}

.cover-score .name {
  max-width: 360rpx;
  font-size: 30rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.panel-tabs {
  margin: 24rpx 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.panel-tab {
  height: 72rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(17, 17, 22, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.panel-tab.active {
  background: #111116;
  border-color: #111116;
  color: #ffffff;
}

.notice {
  margin-bottom: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 12rpx;
  background: #dcfbf5;
  color: #146b68;
  font-size: 26rpx;
  font-weight: 700;
}

.rank-section {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.dish-row {
  display: grid;
  grid-template-columns: 56rpx 124rpx 1fr;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 2rpx solid rgba(17, 17, 22, 0.06);
  box-shadow: 0 14rpx 34rpx rgba(17, 17, 22, 0.07);
}

.dish-row.featured {
  grid-template-columns: 1fr;
  padding: 22rpx;
  background: #111116;
  color: #ffffff;
}

.rank-number {
  color: #f2543d;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 900;
}

.featured .rank-number {
  color: #e8ff55;
  font-size: 56rpx;
}

.dish-image {
  width: 124rpx;
  height: 124rpx;
  border-radius: 12rpx;
  background: #d9ece6;
}

.hero-image,
.featured .poster {
  width: 100%;
  height: 320rpx;
}

.poster {
  background:
    radial-gradient(circle at 34% 38%, #f7ca45 0 18%, transparent 19%),
    radial-gradient(circle at 58% 48%, #f2543d 0 15%, transparent 16%),
    radial-gradient(circle at 48% 54%, #1b8f8f 0 22%, transparent 23%),
    #ffe5b7;
}

.dish-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.dish-name {
  font-size: 32rpx;
  line-height: 1.16;
  color: #111116;
  font-weight: 900;
}

.featured .dish-name {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 48rpx;
}

.dish-place,
.dish-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.42;
  color: #57636b;
}

.featured .dish-place,
.featured .dish-desc {
  color: rgba(255, 255, 255, 0.72);
}

.dish-desc {
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.rating-line {
  grid-column: 2 / 4;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.featured .rating-line {
  grid-column: auto;
}

.dish-score {
  color: #111116;
  font-size: 42rpx;
  font-weight: 900;
}

.featured .dish-score {
  color: #ffffff;
}

.rating-count {
  color: #69747a;
  font-size: 22rpx;
  font-weight: 700;
}

.featured .rating-count {
  color: rgba(255, 255, 255, 0.66);
}

.stars {
  grid-column: 2 / 4;
  display: flex;
  gap: 10rpx;
}

.featured .stars {
  grid-column: auto;
}

.star {
  width: 52rpx;
  height: 52rpx;
  border-radius: 10rpx;
  background: #fff0c9;
  color: #a96700;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.featured .star {
  background: rgba(232, 255, 85, 0.16);
  color: #e8ff55;
}

.empty {
  padding: 70rpx 0;
  text-align: center;
  color: #57636b;
  font-size: 28rpx;
}

.form-card {
  padding: 26rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(17, 17, 22, 0.06);
  box-shadow: 0 14rpx 34rpx rgba(17, 17, 22, 0.07);
}

.form-title {
  display: block;
  margin-bottom: 26rpx;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 900;
}

.field {
  margin-bottom: 24rpx;
}

.field-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #111116;
  font-weight: 800;
}

input,
textarea {
  width: 100%;
  border-radius: 12rpx;
  border: 2rpx solid rgba(17, 17, 22, 0.12);
  background: #fffdf8;
  color: #111116;
  font-size: 28rpx;
  box-sizing: border-box;
}

input {
  height: 82rpx;
  padding: 0 22rpx;
}

textarea {
  min-height: 180rpx;
  padding: 20rpx 22rpx;
  line-height: 1.5;
}

.category-scroll {
  margin-top: 14rpx;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 12rpx;
}

.category-chip {
  padding: 12rpx 18rpx;
  border-radius: 10rpx;
  background: #e8ff55;
  color: #111116;
  font-size: 24rpx;
  font-weight: 800;
}

.image-picker {
  min-height: 220rpx;
  border-radius: 14rpx;
  border: 2rpx dashed #1b8f8f;
  background: #dcfbf5;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 300rpx;
}

.image-empty {
  height: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.image-title {
  font-size: 30rpx;
  color: #146b68;
  font-weight: 900;
}

.image-note {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5d7774;
}

.image-meta {
  margin: 12rpx 0 24rpx;
  display: flex;
  justify-content: space-between;
  color: #57636b;
  font-size: 24rpx;
}

.image-meta text:last-child {
  color: #f2543d;
  font-weight: 800;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 12rpx;
  background: #f2543d;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
}

.submit-btn::after {
  border: none;
}
