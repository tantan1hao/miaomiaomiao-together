page {
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #dfdfdf;
}

text,
view,
image,
input,
button {
  box-sizing: border-box;
}

.reg-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  padding-right: 7px;
  padding-bottom: 7px;
  padding-left: 7px;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.18) 0, transparent 18%, rgba(0, 0, 0, 0.035) 100%),
    repeating-linear-gradient(90deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 18px),
    #dfdfdf;
}

.paper-sheet {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  border: 1px solid rgba(0, 0, 0, 0.9);
  color: #0b0b0b;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.34) 0, transparent 9%, transparent 88%, rgba(0, 0, 0, 0.034) 100%),
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 4px),
    repeating-linear-gradient(90deg, rgba(0, 0, 0, 0.009) 0, rgba(0, 0, 0, 0.009) 1px, transparent 1px, transparent 7px),
    #f6f6f2;
  box-shadow:
    0 9px 20px rgba(0, 0, 0, 0.22),
    0 1px 0 rgba(255, 255, 255, 0.64),
    inset 6px 0 9px rgba(0, 0, 0, 0.028),
    inset -7px 0 11px rgba(0, 0, 0, 0.042);
  transform: rotate(-0.22deg);
  transform-origin: 52% 48%;
}

.paper-grain {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 0;
  opacity: 0.46;
  background:
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 3px),
    repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.36) 0, rgba(255, 255, 255, 0.36) 1px, transparent 1px, transparent 17px),
    radial-gradient(circle, rgba(0, 0, 0, 0.052) 0, rgba(0, 0, 0, 0.052) 0.42px, transparent 0.88px);
  background-size: 100% 3px, 17px 100%, 9px 9px;
}

.paper-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 8px 8px 6px;
}

.issue-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 18px;
  padding: 0 1px;
  border-top: 1px solid rgba(0, 0, 0, 0.82);
  border-bottom: 1px solid rgba(0, 0, 0, 0.72);
  color: #353535;
  font-size: 8px;
  font-weight: 800;
  line-height: 18px;
  white-space: nowrap;
}

.issue-strip text:first-child {
  color: #b31921;
}

.section-title {
  display: block;
  padding: 5px 0 3px;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 24px;
  font-weight: 900;
  line-height: 1.1;
  text-align: center;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.16);
}

.double-rule {
  height: 6px;
  border-top: 2px solid rgba(0, 0, 0, 0.86);
  border-bottom: 1px solid rgba(0, 0, 0, 0.68);
}

.reg-body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding-top: 12px;
  overflow-y: auto;
}

.profile-card {
  padding: 8px 0 10px;
  border-top: 3px solid #111;
  border-bottom: 1px solid rgba(0, 0, 0, 0.58);
}

.profile-main {
  display: flex;
  align-items: stretch;
  gap: 12px;
}

.profile-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 4px;
}

.profile-name {
  display: block;
  overflow: hidden;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 25px;
  font-weight: 900;
  line-height: 1;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.16);
}

.profile-line {
  display: block;
  color: #303030;
  font-size: 11px;
  font-weight: 750;
  line-height: 1.25;
}

.profile-status-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  margin-top: 10px;
  border-top: 1px solid #111;
  border-left: 1px solid #111;
}

.profile-status-grid view {
  min-width: 0;
  padding: 5px 4px;
  border-right: 1px solid #111;
  border-bottom: 1px solid #111;
  background: rgba(255, 255, 255, 0.28);
}

.profile-status-grid text {
  display: block;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-status-grid text:first-child {
  color: #b31921;
  font-size: 9px;
  font-weight: 900;
  line-height: 1.1;
}

.profile-status-grid text:last-child {
  margin-top: 3px;
  color: #111;
  font-size: 10px;
  font-weight: 900;
  line-height: 1.1;
}

.reg-lead {
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.44);
}

.kicker {
  display: block;
  color: #b31921;
  font-size: 10px;
  font-weight: 900;
  line-height: 12px;
}

.reg-headline {
  display: block;
  margin-top: 4px;
  color: #050505;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 22px;
  font-weight: 900;
  line-height: 1.05;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.16);
}

.lead-deck {
  display: block;
  margin-top: 6px;
  color: #282828;
  font-size: 12px;
  font-weight: 600;
  line-height: 1.32;
}

.avatar-button {
  flex: 0 0 96px;
  height: 96px;
  padding: 0;
  border: 1px solid rgba(0, 0, 0, 0.82);
  border-radius: 0;
  background: #fbfbf7;
  overflow: hidden;
}

.avatar-button::after {
  border: none;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  width: 100%;
  height: 100%;
  gap: 4px;
  color: #b31921;
  font-size: 13px;
  font-weight: 900;
  background:
    radial-gradient(circle, rgba(0, 0, 0, 0.16) 0, rgba(0, 0, 0, 0.16) 1px, transparent 1.4px),
    #fbfbf7;
  background-size: 8px 8px, 100% 100%;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.field-label {
  color: #050505;
  font-size: 12px;
  font-weight: 900;
}

.reg-input {
  width: 100%;
  height: 44px;
  padding: 0 12px;
  border: 2px solid rgba(0, 0, 0, 0.82);
  color: #050505;
  background: #fbfbf7;
  font-size: 15px;
  font-weight: 700;
}

.submit-button {
  width: 100%;
  height: 48px;
  margin-top: 6px;
  border-radius: 0;
  color: #fff;
  background: #b31921;
  font-size: 15px;
  font-weight: 900;
  text-shadow: 0.3px 0.3px 0.45px rgba(0, 0, 0, 0.18);
}

.submit-button::after {
  border: none;
}

.submit-button[disabled] {
  color: #f4f4f0;
  background: #6b6b66;
}

.logout-button {
  width: 100%;
  height: 42px;
  margin-top: 0;
  border: 2px solid #111;
  border-radius: 0;
  color: #b31921;
  background: #fffdf7;
  font-size: 14px;
  font-weight: 900;
}

.logout-button::after {
  border: none;
}

.reg-meta {
  margin-top: 4px;
  padding-top: 8px;
  border-top: 1px solid rgba(0, 0, 0, 0.36);
  color: #4b4b4b;
  font-size: 10px;
  font-weight: 600;
  line-height: 1.4;
}

.reg-meta text {
  display: block;
}

.paper-footer {
  display: flex;
  flex: 0 0 22px;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 3px;
  border-top: 1px solid rgba(0, 0, 0, 0.72);
  color: #4b4b4b;
  font-size: 9px;
  font-weight: 800;
  line-height: 11px;
}

.paper-footer text:last-child {
  color: #b31921;
}

/* Poster newspaper pass */
.reg-page {
  padding-right: 10px;
  padding-bottom: 10px;
  padding-left: 10px;
  background:
    radial-gradient(circle, rgba(0, 0, 0, 0.04) 0, rgba(0, 0, 0, 0.04) 0.7px, transparent 1.1px),
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 6px),
    #d9d7d1;
  background-size: 11px 11px, 100% 6px, 100% 100%;
}

.paper-sheet {
  border: none;
  background:
    linear-gradient(96deg, rgba(0, 0, 0, 0.055) 0, transparent 7%, transparent 86%, rgba(0, 0, 0, 0.05) 100%),
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1px, transparent 1px, transparent 4px),
    radial-gradient(circle, rgba(0, 0, 0, 0.04) 0, rgba(0, 0, 0, 0.04) 0.55px, transparent 0.95px),
    #f7f5ee;
  background-size: 100% 100%, 100% 4px, 12px 12px, 100% 100%;
  box-shadow:
    0 12px 26px rgba(0, 0, 0, 0.26),
    0 0 0 1px rgba(0, 0, 0, 0.24),
    inset 0 0 0 1px rgba(255, 255, 255, 0.4);
}

.issue-strip {
  height: 17px;
  border-top: 2px solid rgba(0, 0, 0, 0.9);
  border-bottom: 1px solid rgba(0, 0, 0, 0.8);
  color: #121212;
}

.section-title {
  text-align: left;
  font-size: 27px;
  line-height: 0.98;
  border-bottom: 11px solid rgba(179, 25, 33, 0.22);
}

.double-rule {
  border-top: 3px solid #111;
}

.reg-lead,
.reg-meta {
  border-color: #111;
}

.reg-headline {
  font-size: 25px;
  line-height: 0.98;
}

.avatar-button,
.reg-input {
  border: 2px solid #111;
  background: #fffdf7;
}

.avatar-placeholder {
  color: #b31921;
}

.submit-button {
  box-shadow: 4px 4px 0 #111;
}
