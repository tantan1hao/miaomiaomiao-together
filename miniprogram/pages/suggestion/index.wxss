.container {
  min-height: 100vh;
  background-color: #e9e3d6;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.form {
  background-color: #f7f4ec;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
  font-weight: 500;
}

.content-input {
  width: 100%;
  min-height: 300rpx;
  background-color: #e9e3d6;
  border: 2rpx solid #111111;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #fff;
  line-height: 1.6;
}

.content-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12rpx;
}

.contact-input {
  width: 100%;
  height: 80rpx;
  background-color: #e9e3d6;
  border: 2rpx solid #111111;
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #fff;
}

.contact-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.btn-wrapper {
  margin-bottom: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background-color: #b31921;
  border-radius: 48rpx;
  border: none;
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn.disabled {
  opacity: 0.5;
}

.submit-btn::after {
  border: none;
}

/* Poster newspaper redesign */
.container {
  min-height: 100vh;
  padding: 32rpx 22rpx 58rpx;
  background:
    radial-gradient(circle, rgba(0, 0, 0, 0.036) 0, rgba(0, 0, 0, 0.036) 0.7px, transparent 1.1px),
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1rpx, transparent 1rpx, transparent 6rpx),
    #e9e3d6;
}

.header {
  margin-bottom: 26rpx;
  padding: 16rpx 0 12rpx;
  border-top: 5rpx solid #111111;
  border-bottom: 3rpx solid #111111;
  text-align: left;
}

.title {
  color: #111111;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 62rpx;
  font-weight: 900;
  line-height: 1;
}

.form {
  position: relative;
  margin-bottom: 32rpx;
  padding: 28rpx;
  border: 3rpx solid #111111;
  border-radius: 0;
  background:
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.014) 0, rgba(0, 0, 0, 0.014) 1rpx, transparent 1rpx, transparent 6rpx),
    #f7f4ec;
  box-shadow: 8rpx 8rpx 0 rgba(0, 0, 0, 0.18);
}

.form::before {
  content: 'LETTER TO EDITOR';
  display: block;
  margin-bottom: 24rpx;
  padding: 8rpx 10rpx;
  color: #ffffff;
  background: #b31921;
  font-size: 20rpx;
  font-weight: 900;
}

.label {
  color: #111111;
  font-weight: 900;
}

.content-input,
.contact-input {
  border-radius: 0;
  border: 2rpx solid #111111;
  color: #111111;
  background: #fffdf7;
}

.char-count {
  color: #b31921;
  font-weight: 900;
}

.submit-btn {
  height: 88rpx;
  border-radius: 0;
  color: #ffffff;
  background: #b31921;
  box-shadow: 6rpx 6rpx 0 #111111;
  font-weight: 900;
}

.submit-btn.disabled {
  color: #777777;
  background: #d8d2c6;
  box-shadow: none;
}
