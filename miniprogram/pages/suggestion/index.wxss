.container {
  min-height: 100vh;
  background-color: #1a1a2e;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.form {
  background-color: #16213e;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
  font-weight: 500;
}

.content-input {
  width: 100%;
  min-height: 300rpx;
  background-color: #1a1a2e;
  border: 2rpx solid #2d3a5a;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #fff;
  line-height: 1.6;
}

.content-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12rpx;
}

.contact-input {
  width: 100%;
  height: 80rpx;
  background-color: #1a1a2e;
  border: 2rpx solid #2d3a5a;
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #fff;
}

.contact-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.btn-wrapper {
  margin-bottom: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background-color: #4fc3f7;
  border-radius: 48rpx;
  border: none;
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn.disabled {
  opacity: 0.5;
}

.submit-btn::after {
  border: none;
}
