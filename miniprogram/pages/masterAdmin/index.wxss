page {
  background-color: #1a1a2e;
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  padding-bottom: 150rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #eaeaea;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #888888;
}

.quick-entry {
  background-color: #16213e;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #4fc3f7;
}

.quick-entry-title {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 16rpx;
}

.quick-entry-btn {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #1a1a2e;
  border-radius: 12rpx;
}

.quick-entry-text {
  font-size: 30rpx;
  color: #4fc3f7;
  font-weight: bold;
}

.quick-entry-arrow {
  font-size: 28rpx;
  color: #4fc3f7;
}

.stats-section {
  background-color: #16213e;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.school-section {
  background-color: #16213e;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #eaeaea;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.collapse-arrow {
  font-size: 20rpx;
  color: #888888;
  transition: transform 0.3s ease;
}

.collapse-arrow.expanded {
  transform: rotate(180deg);
}

.collapse-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, opacity 0.3s ease, padding 0.3s ease;
  opacity: 0;
  padding-top: 0;
}

.collapse-content.expanded {
  max-height: 10000rpx;
  opacity: 1;
  padding-top: 24rpx;
}

.add-btn {
  font-size: 26rpx;
  color: #4fc3f7;
  padding: 8rpx 20rpx;
  background-color: rgba(79, 195, 247, 0.1);
  border-radius: 8rpx;
}

.refresh-btn {
  font-size: 24rpx;
  color: #4fc3f7;
  padding: 6rpx 16rpx;
  background-color: rgba(79, 195, 247, 0.1);
  border-radius: 6rpx;
}

.global-stats {
  background-color: #1a1a2e;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.global-stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.global-stats-item:first-child {
  flex: 5;
}

.global-stats-item:last-child {
  flex: 2;
}

.global-stats-divider {
  width: 2rpx;
  height: 80rpx;
  background-color: #2d3a5a;
}

.global-stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4fc3f7;
}

.global-stats-label {
  font-size: 24rpx;
  color: #888888;
  margin-top: 8rpx;
}

.stats-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stats-card {
  width: calc(50% - 8rpx);
  background-color: #1a1a2e;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.stats-school-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #eaeaea;
  margin-bottom: 16rpx;
  text-align: center;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #4fc3f7;
}

.stats-label {
  font-size: 22rpx;
  color: #888888;
  margin-top: 4rpx;
}

.stats-divider {
  width: 2rpx;
  height: 50rpx;
  background-color: #2d3a5a;
}

.school-list {

}

.school-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background-color: #1a1a2e;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.school-order {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
}

.order-btn {
  width: 48rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #4fc3f7;
  background-color: rgba(79, 195, 247, 0.1);
  border-radius: 6rpx;
}

.order-btn.disabled {
  color: #444444;
  background-color: transparent;
}

.order-num {
  font-size: 24rpx;
  color: #888888;
  margin: 4rpx 0;
}

.school-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.school-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #eaeaea;
  margin-bottom: 6rpx;
}

.school-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.school-abbr {
  font-size: 24rpx;
  color: #4fc3f7;
}

.school-admin {
  font-size: 22rpx;
  color: #888888;
}

.school-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
}

.action-btn.edit {
  background-color: rgba(79, 195, 247, 0.1);
  color: #4fc3f7;
}

.action-btn.delete {
  background-color: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
}

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: #888888;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background-color: #1a1a2e;
  border-top: 2rpx solid #2d3a5a;
}

.back-btn {
  height: 88rpx;
  background-color: #4fc3f7;
  color: #1a1a2e;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background-color: #16213e;
  border-radius: 24rpx;
  padding: 40rpx;
  border: 2rpx solid #2d3a5a;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #eaeaea;
  margin-bottom: 32rpx;
  text-align: center;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #1a1a2e;
  border: 2rpx solid #2d3a5a;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #eaeaea;
  box-sizing: border-box;
}

.form-tip {
  font-size: 22rpx;
  color: #4fc3f7;
  margin-top: 8rpx;
  display: block;
}

.modal-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background-color: #2d3a5a;
  color: #888888;
}

.modal-btn.confirm {
  background-color: #4fc3f7;
  color: #1a1a2e;
}

.suggestion-section {
  background-color: #16213e;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.suggestion-list {
  padding: 0 24rpx 24rpx 24rpx;
}

.suggestion-item {
  background-color: #1a1a2e;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #2d3a5a;
}

.suggestion-item:last-child {
  margin-bottom: 0;
}

.suggestion-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.suggestion-time {
  font-size: 24rpx;
  color: #888888;
}

.suggestion-content {
  font-size: 28rpx;
  color: #eaeaea;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.suggestion-contact {
  font-size: 24rpx;
  color: #4fc3f7;
  padding-top: 12rpx;
  border-top: 1rpx solid #2d3a5a;
}

.contact-label {
  color: #888888;
}

.contact-value {
  color: #4fc3f7;
}

