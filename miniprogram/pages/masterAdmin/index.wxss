page {
  background-color: #e9e3d6;
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  padding-bottom: 150rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #eaeaea;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #888888;
}

.quick-entry {
  background-color: #f7f4ec;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #b31921;
}

.quick-entry-title {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 16rpx;
}

.quick-entry-btn {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #e9e3d6;
  border-radius: 12rpx;
}

.quick-entry-text {
  font-size: 30rpx;
  color: #b31921;
  font-weight: bold;
}

.quick-entry-arrow {
  font-size: 28rpx;
  color: #b31921;
}

.stats-section {
  background-color: #f7f4ec;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.school-section {
  background-color: #f7f4ec;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #eaeaea;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.collapse-arrow {
  font-size: 20rpx;
  color: #888888;
  transition: transform 0.3s ease;
}

.collapse-arrow.expanded {
  transform: rotate(180deg);
}

.collapse-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, opacity 0.3s ease, padding 0.3s ease;
  opacity: 0;
  padding-top: 0;
}

.collapse-content.expanded {
  max-height: 10000rpx;
  opacity: 1;
  padding-top: 24rpx;
}

.add-btn {
  font-size: 26rpx;
  color: #b31921;
  padding: 8rpx 20rpx;
  background-color: rgba(79, 195, 247, 0.1);
  border-radius: 8rpx;
}

.refresh-btn {
  font-size: 24rpx;
  color: #b31921;
  padding: 6rpx 16rpx;
  background-color: rgba(79, 195, 247, 0.1);
  border-radius: 6rpx;
}

.global-stats {
  background-color: #e9e3d6;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.global-stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.global-stats-item:first-child {
  flex: 5;
}

.global-stats-item:last-child {
  flex: 2;
}

.global-stats-divider {
  width: 2rpx;
  height: 80rpx;
  background-color: #111111;
}

.global-stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #b31921;
}

.global-stats-label {
  font-size: 24rpx;
  color: #888888;
  margin-top: 8rpx;
}

.stats-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stats-card {
  width: calc(50% - 8rpx);
  background-color: #e9e3d6;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.stats-school-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #eaeaea;
  margin-bottom: 16rpx;
  text-align: center;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #b31921;
}

.stats-label {
  font-size: 22rpx;
  color: #888888;
  margin-top: 4rpx;
}

.stats-divider {
  width: 2rpx;
  height: 50rpx;
  background-color: #111111;
}

.school-list {

}

.school-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background-color: #e9e3d6;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.school-order {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
}

.order-btn {
  width: 48rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #b31921;
  background-color: rgba(79, 195, 247, 0.1);
  border-radius: 6rpx;
}

.order-btn.disabled {
  color: #444444;
  background-color: transparent;
}

.order-num {
  font-size: 24rpx;
  color: #888888;
  margin: 4rpx 0;
}

.school-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.school-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #eaeaea;
  margin-bottom: 6rpx;
}

.school-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.school-abbr {
  font-size: 24rpx;
  color: #b31921;
}

.school-admin {
  font-size: 22rpx;
  color: #888888;
}

.school-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
}

.action-btn.edit {
  background-color: rgba(79, 195, 247, 0.1);
  color: #b31921;
}

.action-btn.delete {
  background-color: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
}

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: #888888;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background-color: #e9e3d6;
  border-top: 2rpx solid #111111;
}

.back-btn {
  height: 88rpx;
  background-color: #b31921;
  color: #e9e3d6;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background-color: #f7f4ec;
  border-radius: 24rpx;
  padding: 40rpx;
  border: 2rpx solid #111111;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #eaeaea;
  margin-bottom: 32rpx;
  text-align: center;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #e9e3d6;
  border: 2rpx solid #111111;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #eaeaea;
  box-sizing: border-box;
}

.form-tip {
  font-size: 22rpx;
  color: #b31921;
  margin-top: 8rpx;
  display: block;
}

.modal-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background-color: #111111;
  color: #888888;
}

.modal-btn.confirm {
  background-color: #b31921;
  color: #e9e3d6;
}

.suggestion-section {
  background-color: #f7f4ec;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.suggestion-list {
  padding: 0 24rpx 24rpx 24rpx;
}

.suggestion-item {
  background-color: #e9e3d6;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #111111;
}

.suggestion-item:last-child {
  margin-bottom: 0;
}

.suggestion-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.suggestion-time {
  font-size: 24rpx;
  color: #888888;
}

.suggestion-content {
  font-size: 28rpx;
  color: #eaeaea;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.suggestion-contact {
  font-size: 24rpx;
  color: #b31921;
  padding-top: 12rpx;
  border-top: 1rpx solid #111111;
}

.contact-label {
  color: #888888;
}

.contact-value {
  color: #b31921;
}

/* Poster newspaper redesign */
page {
  background:
    radial-gradient(circle, rgba(0, 0, 0, 0.036) 0, rgba(0, 0, 0, 0.036) 0.7px, transparent 1.1px),
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0, rgba(0, 0, 0, 0.018) 1rpx, transparent 1rpx, transparent 6rpx),
    #e9e3d6;
  color: #111111;
}

.container {
  padding: 24rpx 20rpx 154rpx;
}

.header {
  align-items: stretch;
  margin-bottom: 20rpx;
  padding: 16rpx 0 12rpx;
  border-top: 5rpx solid #111111;
  border-bottom: 3rpx solid #111111;
}

.title {
  color: #111111;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 50rpx;
  font-weight: 900;
  line-height: 1;
  text-align: left;
}

.subtitle {
  color: #b31921;
  font-weight: 900;
}

.quick-entry,
.stats-section,
.school-section,
.suggestion-section,
.global-stats,
.stats-card,
.school-item,
.suggestion-item,
.modal-content {
  border-radius: 0;
  border: 3rpx solid #111111;
  background:
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.014) 0, rgba(0, 0, 0, 0.014) 1rpx, transparent 1rpx, transparent 6rpx),
    #f7f4ec;
  box-shadow: 6rpx 6rpx 0 rgba(0, 0, 0, 0.16);
}

.quick-entry,
.stats-section,
.school-section,
.suggestion-section {
  margin-bottom: 20rpx;
  padding: 20rpx;
  overflow: visible;
}

.quick-entry {
  border-left: 18rpx solid #b31921;
}

.quick-entry-title,
.section-title {
  color: #111111;
  font-family: Georgia, 'Times New Roman', serif;
  font-weight: 900;
}

.section-title::before {
  content: '';
  display: inline-block;
  width: 18rpx;
  height: 18rpx;
  margin-right: 8rpx;
  background: #b31921;
}

.quick-entry-btn {
  border-radius: 0;
  border: 2rpx solid #111111;
  background: #f7f4ec;
}

.quick-entry-text,
.quick-entry-arrow,
.add-btn,
.refresh-btn,
.school-abbr,
.school-admin,
.global-stats-value,
.stats-value,
.suggestion-contact,
.contact-value {
  color: #b31921;
  font-weight: 900;
}

.global-stats-value,
.stats-value {
  font-family: Georgia, 'Times New Roman', serif;
}

.global-stats-label,
.stats-label,
.suggestion-time,
.contact-label,
.form-label,
.form-tip {
  color: #333333;
  font-weight: 800;
}

.global-stats-divider,
.stats-divider {
  background: #111111;
}

.school-name,
.stats-school-name,
.suggestion-content,
.modal-title {
  color: #111111;
  font-weight: 900;
}

.order-btn,
.action-btn,
.modal-btn.cancel {
  border-radius: 0;
  border: 2rpx solid #111111;
  color: #111111;
  background: #f7f4ec;
}

.action-btn.delete {
  color: #b31921;
}

.add-btn,
.refresh-btn,
.modal-btn.confirm,
.back-btn {
  border-radius: 0;
  color: #ffffff;
  background: #b31921;
  box-shadow: 4rpx 4rpx 0 #111111;
}

.form-input {
  border-radius: 0;
  border: 2rpx solid #111111;
  color: #111111;
  background: #fffdf7;
}

.bottom-actions {
  background:
    repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.016) 0, rgba(0, 0, 0, 0.016) 1rpx, transparent 1rpx, transparent 6rpx),
    #e9e3d6;
  border-top: 3rpx solid #111111;
}

.back-btn {
  width: 100%;
}

.modal-mask {
  background: rgba(0, 0, 0, 0.55);
}

.modal-content {
  background: #f7f4ec;
}

.collapse-arrow,
.order-num {
  color: #111111;
}
